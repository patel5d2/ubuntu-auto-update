# Ubuntu Auto-Update — environment variable contract
# Copy to .env, fill in values, then `docker-compose --env-file .env up`.
# Anything marked REQUIRED has no working default.

# ─── Backend (Go API) ─────────────────────────────────────────────────────────

# REQUIRED. Postgres DSN; pgx-style URL.
DATABASE_URL=postgres://uau:uau@localhost:5432/uau_db?sslmode=disable

# REQUIRED. Web UI login credentials. Compared with constant-time equality.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# REQUIRED. Pre-shared token agents present at /api/v1/enroll to receive a
# long-lived bearer token. Rotate by changing this value and re-enrolling.
ENROLLMENT_TOKEN=dev-enrollment-token

# Listening port for the API. Default 8080.
API_PORT=8080

# Comma-separated origins allowed by both CORS and the WebSocket upgrader.
# Default: http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Set to "production" to mark the auth cookie Secure. Anything else = dev mode.
ENVIRONMENT=development

# AES-GCM key used to encrypt SSH private keys at rest. Must be 16, 24, or
# 32 raw bytes. Default path: ./encryption.key (resolved against the API
# process's working directory).
ENCRYPTION_KEY_FILE=./encryption.key

# Optional. Path to OpenSSH known_hosts file used to verify SSH host keys
# when the API connects to managed hosts. Default: ./known_hosts.
KNOWN_HOSTS_FILE=./known_hosts

# ─── Frontend (Vite dev server) ───────────────────────────────────────────────

# Where the API lives. Empty string means "same origin" (use the Vite proxy).
VITE_API_URL=

# Optional. Override the WebSocket base URL. Defaults to the page origin
# with ws:/wss: derived from window.location.protocol.
VITE_WS_URL=

# Used by vite.config.ts as the proxy target during `npm run dev`.
VITE_PROXY_TARGET=http://localhost:8080
